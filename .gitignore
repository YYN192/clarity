# Added by code-review-graph
.code-review-graph/

# ─── Native build output ───────────────────────────────────────────────
# `/build/` above is root-anchored only, so it does NOT match ios/build,
# macos/build, etc. Xcode writes tens of MB of build state there
# (XCBuildData/build.db, task-store.msgpack). Catch every platform:
**/build/

# Xcode per-user state
**/xcuserdata/
*.xcuserstate

# ─── Scratch / working artifacts ───────────────────────────────────────
# Plan files and unzipped design references — local working material.
.artifacts/

# Editor workspace settings (generated by tooling installers)
.vscode/

# ─── Other AI assistants' configs ──────────────────────────────────────
# Generated by `code-review-graph install --platform all`. This project is
# driven with Claude Code, so only AGENTS.md, CLAUDE.md, .claude/ and
# .mcp.json are kept. Delete these lines if you adopt one of these tools.
.codebuddy/
.cursorrules
.gemini/
.kiro/
.qoder/
.windsurfrules
CODEBUDDY.md
GEMINI.md
QODER.md
opencode.jsonc
