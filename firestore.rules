rules_version = '2';

// Deploy with: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    // Push-notification device tokens, keyed by the FCM token itself.
    // Reads are denied outright — only the alert dispatcher reads these, and it
    // uses the Admin SDK, which bypasses rules entirely.
    //
    // Ownership is enforced by uid. This replaced a rule that allowed
    // unauthenticated create/update and `delete: if true`, under which anyone
    // holding a device's token could silently unregister it from severe-weather
    // alerts or repoint it at another location. The app now signs in
    // anonymously at startup (see _ensureSignedIn in main.dart), so a uid is
    // always available — without that, this rule would lock every device out.
    match /fcm_tokens/{token} {
      allow read: if false;

      allow create: if request.auth != null
                    && request.resource.data.token == token
                    && request.resource.data.uid == request.auth.uid;

      // Every update must leave the document owned by the caller, so it can
      // never be reassigned to someone else.
      //
      // The `uid == null` arm is a migration allowance: documents written
      // before this rule carry a null uid (tokens could be registered while
      // signed out), and without it a device could not adopt its own existing
      // token document — it would simply stop updating its location. Claiming
      // an unowned document still requires already knowing the token. Remove
      // this arm once no null-uid documents remain.
      allow update: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && (!('uid' in resource.data)
                        || resource.data.uid == null
                        || resource.data.uid == request.auth.uid);

      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
    }

    // Bookmarked cities, scoped under the owning uid so no query needs an
    // index and the rule is a straight uid comparison. Anonymous users have a
    // uid too, and linking to a real account preserves it — so an upgraded
    // account keeps its saved cities.
    match /users/{uid}/saved_cities/{cityId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
