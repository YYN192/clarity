rules_version = '2';

// Deploy with: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    // Push-notification device tokens.
    // A client may register/update/remove its own token document.
    // Reads are denied — only the Admin SDK (backend / Cloud Functions) reads these.
    //
    // Kept exactly as published in the console. Note it deliberately does NOT
    // require request.auth: NotificationService stores a token before sign-in
    // (uid is nullable in _storeToken), so adding an auth check here would stop
    // signed-out devices registering for alerts.
    match /fcm_tokens/{token} {
      allow create, update: if request.resource.data.token == token;
      allow delete: if true;
      allow read: if false;
    }

    // Bookmarked cities, scoped under the owning uid so no query needs an
    // index and the rule is a straight uid comparison. Anonymous users have a
    // uid too, and linking to a real account preserves it — so an upgraded
    // account keeps its saved cities.
    match /users/{uid}/saved_cities/{cityId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
